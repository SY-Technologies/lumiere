#!/usr/bin/env bash
set -euo pipefail

BUILD_DIR="build"
BACKEND=""
FILE=""

usage() {
    echo "usage: run [--build-dir dir] (--tw | --vm) <file>" >&2
}

select_backend() {
    local backend="$1"
    if [[ -n "$BACKEND" && "$BACKEND" != "$backend" ]]; then
        usage
        echo "error: choose exactly one backend: --tw or --vm" >&2
        exit 1
    fi
    BACKEND="$backend"
}

while (($# > 0)); do
    case "$1" in
        --build-dir)
            BUILD_DIR="${2:?missing value for --build-dir}"
            shift 2
            ;;
        --tw|--tree-walker)
            select_backend "--tree-walker"
            shift
            ;;
        --vm)
            select_backend "--vm"
            shift
            ;;
        -*)
            usage
            echo "error: unknown option: $1" >&2
            exit 1
            ;;
        *)
            if [[ -n "$FILE" ]]; then
                usage
                echo "error: provide exactly one source file" >&2
                exit 1
            fi
            FILE="$1"
            shift
            ;;
    esac
done

if [[ -z "$BACKEND" || -z "$FILE" ]]; then
    usage
    exit 1
fi

"$BUILD_DIR/lumiere" "$BACKEND" "$FILE"
